# Copie este arquivo para `.env.local` e preencha com seus valores reais.
# `.env.local` é ignorado pelo git (ver .gitignore).

# --- Supabase ---
# Painel: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave secreta (server-side apenas). NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY=

# --- E-mail (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=

# --- Usado pelos scripts de teste (scripts/create-test-user.mjs etc.) ---
TEST_EMAIL=
TEST_PASSWORD=
